datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  name              String?
  profilePictureUrl String?
  isAdmin           Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  bookmarks         Bookmark[]
  submissions       Submission[]
  courseCompletions ResourceCompletion[]
}

model Problem {
  id              Int            @id
  title           String
  body            String         // Markdown containing LaTeX
  inputFormat     String
  outputFormat    String
  constraints     String
  difficulty      Int            // 1=Easy, 2=Medium, 3=Hard, etc.
  memoryLimitMb   Int
  timeLimitSec    Float
  note            String?
  samples         Json           // Array of sample inputs/outputs/explanations
  hints           Json           // Hints mapping (hint1, hint2, solution_approach)
  videoEditorialId String?
  status          String
  hash            String?        // MD5 hash of the raw scraper JSON file for change tracking
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tags            Tag[]          @relation("ProblemTags")
  editorials      Editorial[]
  templates       TemplateCode[]
  bookmarks       Bookmark[]
  submissions     Submission[]
  resources       Resource[]
}

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  problems Problem[] @relation("ProblemTags")
}

model Editorial {
  id        String   @id @default(uuid())
  problemId Int
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  code      String
  language  String
}

model TemplateCode {
  id        String   @id @default(uuid())
  problemId Int
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  code      String
  language  String
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  problemId Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, problemId])
}

model Submission {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId       Int
  problem         Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  code            String
  language        String
  status          String   // "Accepted" | "WrongAnswer" | "TimeLimitExceeded" | "RuntimeError" | "CompilationError"
  executionTimeMs Int
  sampleResults   Json     // Array storing: [{ passed: boolean, status: string, output: string }]
  createdAt       DateTime @default(now())
}

model Course {
  id              Int       @id // Matches original Course ID from API
  name            String
  description     String?
  image           String?
  instructorImage String?
  instructorName  String?
  difficulty      String?
  isFree          Boolean   @default(false)
  timeInMinutes   Int       @default(0)
  hash            String?   // MD5 hash of the source JSON for change tracking
  fullyScraped    Boolean   @default(false)
  isVisible       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  chapters        Chapter[]
}

model Chapter {
  id        Int        @id // Matches original Chapter ID from API
  courseId  Int
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name      String
  order     Int        // 1-based order index matching syllabus sequence
  playlists Playlist[]
}

model Playlist {
  id        Int        @id // Matches original Playlist ID from API
  chapterId Int
  chapter   Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  name      String
  order     Int        // 1-based order index matching syllabus sequence
  resources Resource[]
}

model Resource {
  id         Int                  @id // Matches original Resource ID from API
  playlistId Int
  playlist   Playlist             @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  name       String
  type       String               // "READING_MATERIAL" | "CODING_PROBLEM" | "VIDEO" | "MCQ" | "QUIZ"
  order      Int                  // 1-based order index matching playlist sequence
  problemId  Int?                 // Nullable link to the global Problem model if type == "CODING_PROBLEM"
  problem    Problem?             @relation(fields: [problemId], references: [id], onDelete: SetNull)
  details    Json?                // Dynamic payload (HTML blocks, MCQ options, Video metadata, or EXTERNAL lists)
  completions ResourceCompletion[]
}

model ResourceCompletion {
  id          String   @id @default(uuid())
  userId      String
  resourceId  Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, resourceId])
}
