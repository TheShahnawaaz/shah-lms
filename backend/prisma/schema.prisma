datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  name              String?
  profilePictureUrl String?
  isAdmin           Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  bookmarks         Bookmark[]
  submissions       Submission[]
}

model Problem {
  id              Int            @id
  title           String
  body            String         // Markdown containing LaTeX
  inputFormat     String
  outputFormat    String
  constraints     String
  difficulty      Int            // 1=Easy, 2=Medium, 3=Hard, etc.
  memoryLimitMb   Int
  timeLimitSec    Float
  note            String?
  samples         Json           // Array of sample inputs/outputs/explanations
  hints           Json           // Hints mapping (hint1, hint2, solution_approach)
  videoEditorialId String?
  status          String
  hash            String?        // MD5 hash of the raw scraper JSON file for change tracking
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tags            Tag[]          @relation("ProblemTags")
  editorials      Editorial[]
  templates       TemplateCode[]
  bookmarks       Bookmark[]
  submissions     Submission[]
}

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  problems Problem[] @relation("ProblemTags")
}

model Editorial {
  id        String   @id @default(uuid())
  problemId Int
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  code      String
  language  String
}

model TemplateCode {
  id        String   @id @default(uuid())
  problemId Int
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  code      String
  language  String
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  problemId Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, problemId])
}

model Submission {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId       Int
  problem         Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  code            String
  language        String
  status          String   // "Accepted" | "WrongAnswer" | "TimeLimitExceeded" | "RuntimeError" | "CompilationError"
  executionTimeMs Int
  sampleResults   Json     // Array storing: [{ passed: boolean, status: string, output: string }]
  createdAt       DateTime @default(now())
}
