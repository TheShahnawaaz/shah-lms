{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShahLMS",
  "version": "../package.json",
  "identifier": "com.shahnawaz.shahlms",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ShahLMS",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxOUNBNDAwQzVEN0ZCOEMKUldTTSs5ZkZBS1NjTVhxa3FnL2NWVS85bzVha3JrakozWDVCWXBOOU5JbC9RS2hGM3R5ZHVuSnAK",
      "endpoints": [
        "https://github.com/TheShahnawaaz/shah-lms/releases/latest/download/latest.json"
      ]
    }
  }
}
